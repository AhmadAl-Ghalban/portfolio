# Public canonical URL of the deployed site (no trailing slash).
# Used for SEO metadata, sitemap, robots, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional. Raises the GitHub API rate limit for the live stats/activity
# section (60 req/h unauthenticated → 5000 req/h with a token).
# Create a fine-grained token with public repo read access only.
# GITHUB_TOKEN=

# Optional. Enables real email delivery from the contact form via Resend
# (https://resend.com — free tier). Without it the form falls back to a
# pre-filled mailto link. Sign up with the same address the site shows as
# its contact email (Resend's free sandbox sender can only deliver to the
# account owner's address until you verify a custom domain).
# RESEND_API_KEY=

# Optional. Custom verified sender, e.g. "Portfolio <contact@yourdomain.com>".
# Defaults to Resend's sandbox sender "onboarding@resend.dev".
# RESEND_FROM=
